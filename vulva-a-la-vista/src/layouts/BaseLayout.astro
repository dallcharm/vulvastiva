---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Vulva a la Vista — Vulvástica',
  description = 'Vulva a la Vista es el juego de mesa didáctico de educación menstrual creado por Vulvástica.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/jpeg" href="/logo.jpg" />
</head>
<body>
  <slot />
</body>
</html>
